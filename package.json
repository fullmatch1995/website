{
  "name": "projekti-im-worker",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create projekti-im-db",
    "db:migrate": "wrangler d1 execute projekti-im-db --file=schema.sql",
    "db:migrate:local": "wrangler d1 execute projekti-im-db --local --file=schema.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.12.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.69.0"
  }
}
